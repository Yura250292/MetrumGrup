# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/metrum_group"

# Authentication
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# AI API Keys (Optional - for AI-powered features)
# Google Gemini - для генерації кошторисів
GEMINI_API_KEY="your-gemini-api-key-here"

# Anthropic Claude - для аналізу архітектурних планів
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# OpenAI API - для інженерного редагування кошторисів
OPENAI_API_KEY="your-openai-api-key-here"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your-telegram-bot-token-from-botfather"
BOT_MODE="polling"  # polling (dev) or webhook (production)
BOT_WEBHOOK_URL=""  # https://yourdomain.com/api/telegram/webhook (для production)
ADMIN_PASSWORD="2233"  # Пароль для доступу адміна до функціоналу прораба
