# Production Environment Variables
# ⚠️ IMPORTANT: Replace ALL values with your actual production credentials
# ⚠️ NEVER commit this file with real values to git!

# Database - Use managed PostgreSQL service (AWS RDS, DigitalOcean, etc.)
DATABASE_URL="postgresql://username:strong_password@your-db-host:5432/metrum_group?sslmode=require"

# Authentication - Generate with: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_RANDOM_32_BYTE_STRING"
AUTH_URL="https://your-production-domain.com"
NEXTAUTH_URL="https://your-production-domain.com"

# AI API Keys - Get from respective providers
# Google Gemini - https://makersuite.google.com/app/apikey
GEMINI_API_KEY="your-production-gemini-api-key"

# Anthropic Claude - https://console.anthropic.com/
ANTHROPIC_API_KEY="your-production-anthropic-api-key"

# OpenAI API - https://platform.openai.com/api-keys
OPENAI_API_KEY="your-production-openai-api-key"

# Optional: Email service (for notifications)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"

# Optional: File storage (AWS S3, Cloudinary, etc.)
# STORAGE_PROVIDER="s3"
# S3_BUCKET_NAME="metrum-group-files"
# S3_REGION="eu-central-1"
# S3_ACCESS_KEY_ID="your-access-key"
# S3_SECRET_ACCESS_KEY="your-secret-key"
