{
  "name": "metrum-group",
  "version": "1.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --config jest.config.ts",
    "test:components": "jest --config jest.config.components.ts",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "npx prisma studio",
    "deploy:check-env": "npx tsx scripts/check-env.ts",
    "deploy:db-status": "npx tsx scripts/db-status.ts",
    "deploy:create-admin": "npx tsx scripts/create-admin.ts",
    "deploy:migrate": "npx prisma db push && npx tsx scripts/db-status.ts",
    "bot:dev": "tsx bot/index.ts",
    "bot:build": "tsc --project tsconfig.bot.json",
    "bot:start": "node dist/bot/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@auth/prisma-adapter": "^2.11.2",
