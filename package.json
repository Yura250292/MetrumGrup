    "@types/pdfmake": "^0.3.2",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
