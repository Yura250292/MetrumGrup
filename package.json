    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.2",
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/react-query": "^5.100.5",
    "@types/archiver": "^7.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "fastest-levenshtein": "^1.0.16",
