    "mammoth": "^1.12.0",
    "marked": "^18.0.2",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.34.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.6.205",
    "pdfmake": "^0.3.7",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.10",
    "prisma": "^6.19.2",
