// 📄 Розпарсені кошториси з Prozorro
model ProzorroEstimateData {
  id            String   @id @default(cuid())
  tenderId      String
  tenderTitle   String
  awardedAmount Decimal  @db.Decimal(12, 2)
  datePublished DateTime

  documentId     String // ID документа з Prozorro
  documentUrl    String // URL оригінального файлу
  documentTitle  String // Назва файлу
  documentFormat String // "application/pdf", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"

  parsedAt    DateTime @default(now())
  parseStatus String   @default("success") // "success", "partial", "failed"
  parseErrors Json? // Помилки парсингу якщо були

  totalItems  Int      @default(0)
  totalAmount Decimal? @db.Decimal(12, 2)

  items  ProzorroEstimateItem[]
  tender ProzorroTender         @relation(fields: [tenderId], references: [id])

  @@index([tenderId])
  @@index([datePublished])
  @@index([parseStatus])
  @@map("prozorro_estimate_data")
}

