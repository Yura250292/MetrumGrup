  budgetBand      String? // 'core' | 'near' | 'context'
  matchedAt       DateTime @default(now())

  estimate Estimate       @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  tender   ProzorroTender @relation(fields: [tenderId], references: [id])

  @@unique([estimateId, tenderId])
  @@index([estimateId])
  @@map("estimate_tender_matches")
