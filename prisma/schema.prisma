generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                    @id @default(cuid())
  email                  String                    @unique
  password               String
  name                   String
  phone                  String?
  avatar                 String?
  firstName              String?
  lastName               String?
  bio                    String?                   @db.Text
  jobTitle               String?
  timezone               String                    @default("Europe/Kyiv")
  locale                 String                    @default("uk")
  dateFormat             String                    @default("DD.MM.YYYY")
  weekStartsOn           Int                       @default(1)
  defaultTaskView        String                    @default("list")
  defaultLandingPage     String                    @default("dashboard")
  notificationPrefsJson  Json?
  workPrefsJson          Json?
  productivityPrefsJson  Json?
  dashboardLayoutJson    Json?
  role                   Role                      @default(CLIENT)
  firmId                 String?
  firm                   Firm?                     @relation(fields: [firmId], references: [id])
  isActive               Boolean                   @default(true)
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  auditLogs              AuditLog[]
  createdEstimates       Estimate[]                @relation("EstimateCreator")
  engineerReviews        Estimate[]                @relation("EngineerReviews")
  financeReviews         Estimate[]                @relation("FinanceReviews")
  financialTemplates     FinancialTemplate[]       @relation("TemplateCreator")
  inventoryTx            InventoryTransaction[]
  newsArticles           NewsArticle[]
  notifications          Notification[]
  pushSubscriptions      PushSubscription[]
  payments               Payment[]
  photoReports           PhotoReport[]
  projectFiles           ProjectFile[]
  clientProjects         Project[]                 @relation("ClientProjects")
  managedProjects        Project[]                 @relation("ManagerProjects")
  aiRenderJobs           AiRenderJob[]
  estimateVersions       EstimateVersion[]
  approvalSteps          EstimateApprovalStep[]
  criticalChanges        EstimateCriticalChange[]
  chatMessages           ChatMessage[]
  chatParticipations     ConversationParticipant[]
  authoredComments       Comment[]                 @relation("CommentAuthor")
  reactions              Reaction[]
  refineHistory          EstimateRefineHistory[]   @relation("RefineHistoryUser")
  projectMemberships     ProjectMember[]           @relation("ProjectMemberUser")
  invitedMembers         ProjectMember[]           @relation("ProjectMemberInviter")
  referenceEstimates     ReferenceEstimate[]       @relation("ReferenceEstimateCreator")
  createdTasks           Task[]                    @relation("TaskCreator")
  taskAssignments        TaskAssignee[]            @relation("TaskAssigneeUser")
  taskAssignerOf         TaskAssignee[]            @relation("TaskAssigneeAssigner")
  taskWatchers           TaskWatcher[]             @relation("TaskWatcherUser")
  checklistItems         ChecklistItem[]           @relation("ChecklistAssignee")
  checklistCompletions   ChecklistItem[]           @relation("ChecklistCompletedBy")
  savedViews             SavedView[]               @relation("SavedViewUser")
  timeLogs               TimeLog[]                 @relation("TimeLogUser")
  timeLogsApproved       TimeLog[]                 @relation("TimeLogApprover")
  hourlyRates            UserHourlyRate[]          @relation("UserHourlyRateUser")
  workSchedule           UserWorkSchedule?         @relation("UserWorkScheduleUser")
  timeOff                TimeOff[]                 @relation("TimeOffUser")
  timeOffApproved        TimeOff[]                 @relation("TimeOffApprover")
  automations            Automation[]              @relation("AutomationCreator")
  webhooks               Webhook[]                 @relation("WebhookCreator")
  projectTemplates       ProjectTemplate[]         @relation("ProjectTemplateCreator")
  taskTemplates          TaskTemplate[]            @relation("TaskTemplateCreator")
  departmentsHead        Department[]              @relation("DepartmentHead")
  teamsLead              Team[]                    @relation("TeamLead")
  teamMemberships        TeamMember[]              @relation("TeamMemberUser")
  integrations           UserIntegration[]         @relation("UserIntegrationUser")
  financeEntriesCreated  FinanceEntry[]            @relation("FinanceEntryCreator")
  financeEntriesUpdated  FinanceEntry[]            @relation("FinanceEntryUpdater")
  financeEntriesApproved FinanceEntry[]            @relation("FinanceEntryApprover")
  financeAttachments     FinanceEntryAttachment[]  @relation("FinanceAttachmentUploader")
  financeTemplates       FinanceExpenseTemplate[]  @relation("FinanceTemplateCreator")
  timesheetsCreated      Timesheet[]               @relation("TimesheetCreator")
  timesheetsUpdated      Timesheet[]               @relation("TimesheetUpdater")
  timesheetsApproved     Timesheet[]               @relation("TimesheetApprover")
  kb2FormsCreated        KB2Form[]                 @relation("KB2FormCreator")
  kb2FormsApproved       KB2Form[]                 @relation("KB2FormApprover")
  kb3FormsCreated        KB3Form[]                 @relation("KB3FormCreator")
  kb3FormsApproved       KB3Form[]                 @relation("KB3FormApprover")
  estimateFinanceSyncs   Estimate[]                @relation("EstimateFinanceSyncer")
  commentReadStates      CommentReadState[]
  aiConversations        AiConversation[]          @relation("AiConversationUser")
  meetings               Meeting[]                 @relation("MeetingCreator")
  employeeProfile        Employee?                 @relation("EmployeeUser")
  materialPriceSnapshots MaterialPriceSnapshot[]   @relation("PriceSnapshotCreator")
  receiptScansCreated    ReceiptScan[]             @relation("ReceiptScanCreator")
  receiptScansApproved   ReceiptScan[]             @relation("ReceiptScanApprover")
  telegramBotUser        TelegramBotUser?          @relation("TelegramBotUserLink")
  stagesResponsible      ProjectStageRecord[]      @relation("ProjectStageResponsible")
  firmAccess             UserFirmAccess[]
  foremanReportsCreated  ForemanReport[]           @relation("ForemanReportCreator")
  foremanReportsReviewed ForemanReport[]           @relation("ForemanReportReviewer")
  foremanReportFiles     ForemanReportAttachment[] @relation("ForemanReportAttachmentUploader")
  ownerConversations     OwnerConversation[]       @relation("OwnerConversationUser")
  ownerChatFolders       OwnerChatFolder[]         @relation("OwnerChatFolderUser")
  supplierPaymentsCreated SupplierPayment[]        @relation("SupplierPaymentCreator")
  supplierPaymentsVoided  SupplierPayment[]        @relation("SupplierPaymentVoider")

  @@index([firmId])
  @@map("users")
}

model Project {
  id                     String                  @id @default(cuid())
  title                  String
  slug                   String                  @unique
  description            String?
  address                String?
  coverImageUrl          String?
  isInternal             Boolean                 @default(false)
  isTestProject          Boolean                 @default(false)
  status                 ProjectStatus           @default(DRAFT)
  currentStage           ProjectStage            @default(DESIGN)
  currentStageRecordId   String?                 @unique
  stageProgress          Int                     @default(0)
  totalBudget            Decimal                 @default(0) @db.Decimal(12, 2)
  totalPaid              Decimal                 @default(0) @db.Decimal(12, 2)
  /// Канонічне джерело плану (Phase 2). Auto-перераховується через
  /// recomputeProjectPlanSource() після estimate sync і stage sync.
  planSource             ProjectPlanSource       @default(NONE)
  /// Publication metadata (Phase 3: draft/published model).
  /// Bump-аться через markProjectPublished() при publish-stages-finance, при
  /// estimate→stages з auto-publish (publicationVersion=0), і у legacy paths.
  /// `dirty` тепер рахується як stage.* ≠ stage.published* (див. dirty-stages
  /// endpoint), а не stages.updatedAt > lastPublishedAt.
  lastPublishedAt        DateTime?
  lastPublishedById      String?
  publicationVersion     Int                     @default(0)
  startDate              DateTime?
  expectedEndDate        DateTime?
  actualEndDate          DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  /// Legacy User-CLIENT FK. Більшість нових проектів обходяться без логіну
  /// клієнта — використовуй clientName або clientCounterpartyId.
  clientId               String?
  /// Display-only імʼя клієнта (free-text "Шиба Ігор" АБО snapshot назви
  /// контрагента). Заповнюється завжди — використовується як єдине джерело
  /// для рендеру списків/деталей, без потреби join-ити User/Counterparty.
  clientName             String?
  /// Опційний FK на Counterparty (книга контрагентів). Якщо проставлений,
  /// `clientName` тримає snapshot назви на момент привʼязки.
  clientCounterpartyId   String?
  managerId              String?
  folderId               String?
  firmId                 String?
  /// Telegram chat (forum) + thread (topic) the bot listens to for this
  /// project. For multi-apartment buildings: every apartment is a Project
  /// pinned to the same chatId but a different threadId. Composite unique
  /// (chatId, threadId) guarantees one project per topic. Both NULL = not
  /// linked (allowed in multiples since NULL ≠ NULL in Postgres uniques).
  telegramChatId         BigInt?
  telegramThreadId       Int?
  telegramLinkedAt       DateTime?
  telegramLinkedById     String?
  auditLogs              AuditLog[]
  completionActs         CompletionAct[]
  crewAssignments        CrewAssignment[]
  equipmentAssigned      Equipment[]
  estimates              Estimate[]
  inventoryTx            InventoryTransaction[]
  payments               Payment[]
  photoReports           PhotoReport[]
  files                  ProjectFile[]
  stages                 ProjectStageRecord[]
  client                 User?                   @relation("ClientProjects", fields: [clientId], references: [id])
  clientCounterparty     Counterparty?           @relation("ProjectClientCounterparty", fields: [clientCounterpartyId], references: [id])
  manager                User?                   @relation("ManagerProjects", fields: [managerId], references: [id])
  conversation           Conversation?
  members                ProjectMember[]
  aiRenderJobs           AiRenderJob[]
  tasks                  Task[]
  taskStatuses           TaskStatus[]
  taskLabels             TaskLabel[]
  taskCustomFields       TaskCustomField[]
  savedViews             SavedView[]             @relation("SavedViewProject")
  userHourlyRates        UserHourlyRate[]        @relation("UserHourlyRateProject")
  automations            Automation[]            @relation("AutomationProject")
  webhooks               Webhook[]               @relation("WebhookProject")
  taskTemplates          TaskTemplate[]          @relation("TaskTemplateProject")
  emailInbox             EmailToTaskInbox?       @relation("EmailInboxProject")
  financeEntries         FinanceEntry[]
  folder                 Folder?                 @relation(fields: [folderId], references: [id], onDelete: SetNull)
  firm                   Firm?                   @relation(fields: [firmId], references: [id])
  financeFolderMirror    Folder?                 @relation("FolderFromProject")
  meetings               Meeting[]
  warehouses             Warehouse[]             @relation("ProjectWarehouses")
  receiptScans           ReceiptScan[]
  materialPriceSnapshots MaterialPriceSnapshot[]
  timesheets             Timesheet[]             @relation("ProjectTimesheets")
  /// Default retention % for KB-2 forms generated under this project (0–100).
  retentionPercent       Decimal                 @default(0) @db.Decimal(5, 2)
  kb2Forms               KB2Form[]               @relation("ProjectKB2Forms")
  kb3Forms               KB3Form[]               @relation("ProjectKB3Forms")
  foremanReports         ForemanReport[]
  supplierPayments       SupplierPayment[]

  @@unique([telegramChatId, telegramThreadId], name: "project_telegram_chat_thread_unique")
  @@index([folderId])
  @@index([isTestProject])
  @@index([firmId])
  @@index([clientCounterpartyId])
  @@index([telegramChatId])
  @@index([telegramThreadId])
  @@map("projects")
}

model ProjectMember {
  id            String      @id @default(cuid())
  projectId     String
  userId        String
  roleInProject ProjectRole
  permissions   Json?
  joinedAt      DateTime    @default(now())
  leftAt        DateTime?
  invitedById   String?
  isActive      Boolean     @default(true)

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation("ProjectMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?   @relation("ProjectMemberInviter", fields: [invitedById], references: [id])

  @@unique([projectId, userId])
  @@index([userId, isActive])
  @@index([projectId, roleInProject])
  @@map("project_members")
}

model ProjectStageRecord {
  id                           String               @id @default(cuid())
  stage                        ProjectStage?
  customName                   String?
  isHidden                     Boolean              @default(false)
  kind                         StageKind            @default(STAGE)
  status                       StageStatus          @default(PENDING)
  progress                     Int                  @default(0)
  notes                        String?
  startDate                    DateTime?
  endDate                      DateTime?
  sortOrder                    Int                  @default(0)
  allocatedBudget              Decimal?             @db.Decimal(12, 2)
  // Об'єм / одиниці виміру / ціна за одиницю для табличної картки
  // «Етапи виконання» (План vs Факт). `unit` — план-одиниця, `factUnit` —
  // факт (зазвичай те саме, але дозволяємо відмінність для довезень
  // у іншій тарі). planVolume × planUnitPrice = планові витрати —
  // upsert-аться у FinanceEntry (source=STAGE_AUTO) при PATCH.
  unit                         String?
  factUnit                     String?
  planVolume                   Decimal?             @db.Decimal(12, 3)
  factVolume                   Decimal?             @db.Decimal(12, 3)
  // Cost (собівартість/закупка) → формує EXPENSE auto-records.
  planUnitPrice                Decimal?             @db.Decimal(12, 2)
  factUnitPrice                Decimal?             @db.Decimal(12, 2)
  // Ціна для замовника → формує INCOME auto-records. Маржа = (client − unit) × volume.
  planClientUnitPrice          Decimal?             @db.Decimal(12, 2)
  factClientUnitPrice          Decimal?             @db.Decimal(12, 2)
  // Phase 3: published-копія, яку зчитує syncStageAutoFinanceEntries і будь-які
  // фінансові звіти. Поки draft (не-published) поля редагуються вільно,
  // фінанси бачать лише останній publish. Backfill = поточні значення.
  publishedPlanVolume          Decimal?             @db.Decimal(12, 3)
  publishedFactVolume          Decimal?             @db.Decimal(12, 3)
  publishedPlanUnitPrice       Decimal?             @db.Decimal(12, 2)
  publishedFactUnitPrice       Decimal?             @db.Decimal(12, 2)
  publishedPlanClientUnitPrice Decimal?             @db.Decimal(12, 2)
  publishedFactClientUnitPrice Decimal?             @db.Decimal(12, 2)
  createdAt                    DateTime             @default(now())
  updatedAt                    DateTime             @updatedAt
  projectId                    String
  project                      Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentStageId                String?
  parent                       ProjectStageRecord?  @relation("StageTree", fields: [parentStageId], references: [id], onDelete: Cascade)
  children                     ProjectStageRecord[] @relation("StageTree")
  responsibleUserId            String?
  responsibleUser              User?                @relation("ProjectStageResponsible", fields: [responsibleUserId], references: [id])
  // Free-text fallback — коли відповідальний не зареєстрований у системі
  // (підрядник, прізвище зі слів). Заповнюється лише якщо responsibleUserId=null.
  responsibleName              String?
  tasks                        Task[]
  financeEntries               FinanceEntry[]       @relation("StageFinanceEntries")
  // Прив'язка до кошторису — для re-sync (estimate items/sections → stage tree).
  // SetNull на видалення секції/item, щоб ручні факт-зміни не пропали.
  sourceEstimateSectionId      String?
  sourceEstimateSection        EstimateSection?     @relation("EstimateSectionToStage", fields: [sourceEstimateSectionId], references: [id], onDelete: SetNull)
  sourceEstimateItemId         String?
  sourceEstimateItem           EstimateItem?        @relation("EstimateItemToStage", fields: [sourceEstimateItemId], references: [id], onDelete: SetNull)

  /// Telegram forum topic this stage receives expense reports from. Bound by
  /// /num <N> in a topic, by forum_topic_created auto-binding, or by manager
  /// in admin UI. The pair (project.telegramChatId, telegramThreadId) is
  /// effectively unique — enforced in code, not at DB level (chatId lives on Project).
  telegramThreadId Int?

  @@index([projectId, stage])
  @@index([projectId, parentStageId])
  @@index([responsibleUserId])
  @@index([sourceEstimateSectionId])
  @@index([sourceEstimateItemId])
  @@index([telegramThreadId])
  @@map("project_stage_records")
}

model Estimate {
  id                    String                   @id @default(cuid())
  number                String                   @unique
  title                 String
  description           String?
  status                EstimateStatus           @default(DRAFT)
  version               Int                      @default(1)
  totalMaterials        Decimal                  @default(0) @db.Decimal(12, 2)
  totalLabor            Decimal                  @default(0) @db.Decimal(12, 2)
  totalOverhead         Decimal                  @default(0) @db.Decimal(12, 2)
  totalAmount           Decimal                  @default(0) @db.Decimal(12, 2)
  discount              Decimal                  @default(0) @db.Decimal(5, 2)
  finalAmount           Decimal                  @default(0) @db.Decimal(12, 2)
  notes                 String?
  sentAt                DateTime?
  approvedAt            DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  projectId             String
  createdById           String
  engineerNotes         String?
  engineerReviewedAt    DateTime?
  engineerReviewedById  String?
  financeNotes          String?
  financeReviewedAt     DateTime?
  financeReviewedById   String?
  finalClientPrice      Decimal                  @default(0) @db.Decimal(12, 2)
  profitAmount          Decimal                  @default(0) @db.Decimal(12, 2)
  profitMarginLabor     Decimal?                 @db.Decimal(5, 2)
  profitMarginMaterials Decimal?                 @db.Decimal(5, 2)
  profitMarginOverall   Decimal                  @default(20) @db.Decimal(5, 2)
  taxAmount             Decimal                  @default(0) @db.Decimal(12, 2)
  taxRate               Decimal                  @default(0) @db.Decimal(5, 2)
  taxationType          TaxationType?
  logisticsCost         Decimal                  @default(0) @db.Decimal(12, 2)
  pdvAmount             Decimal                  @default(0) @db.Decimal(12, 2)
  esvAmount             Decimal                  @default(0) @db.Decimal(12, 2)
  militaryTaxAmount     Decimal                  @default(0) @db.Decimal(12, 2)
  profitTaxAmount       Decimal                  @default(0) @db.Decimal(12, 2)
  unifiedTaxAmount      Decimal                  @default(0) @db.Decimal(12, 2)
  pdfoAmount            Decimal                  @default(0) @db.Decimal(12, 2)
  taxCalculationDetails Json?
  taxCalculatedAt       DateTime?
  items                 EstimateItem[]
  sections              EstimateSection[]
  versions              EstimateVersion[]
  approvalSteps         EstimateApprovalStep[]
  criticalChanges       EstimateCriticalChange[]
  verificationStatus    String? // "passed" | "warnings" | "critical" | "not_verified"
  verificationResults   Json? // повні результати у форматі JSON
  verificationScore     Decimal?                 @db.Decimal(5, 2) // 0-100
  verifiedAt            DateTime?
  verifiedBy            String? // "openai" | "anthropic"
  analysisSummary       String?                  @db.Text // Звіт інженера про аналіз проекту
  prozorroChecked       Boolean                  @default(false) // Чи була перевірка на Prozorro
  prozorroCheckedAt     DateTime? // Коли останній раз перевіряли Prozorro
  prozorroAnalysis      String?                  @db.Text // Аналіз конкурентних тендерів Prozorro
  structuredReport      Json? // StructuredEngineerReport v2 (JSON)
  bidIntelligence       Json? // BidIntelligenceResult (JSON)
  folderId              String?
  createdBy             User                     @relation("EstimateCreator", fields: [createdById], references: [id])
  engineerReviewedBy    User?                    @relation("EngineerReviews", fields: [engineerReviewedById], references: [id])
  financeReviewedBy     User?                    @relation("FinanceReviews", fields: [financeReviewedById], references: [id])
  project               Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder                Folder?                  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  similarTenders        EstimateTenderMatch[]
  conversation          Conversation?
  // Refine history (Stage 6.2)
  refineHistory         EstimateRefineHistory[]  @relation("RefineHistoryEstimate")
  refinedFromHistory    EstimateRefineHistory[]  @relation("RefineHistoryPrevious")
  financeEntries        FinanceEntry[]           @relation("EstimateFinanceEntries")
  kb2Forms              KB2Form[]                @relation("EstimateKB2Forms")
  financeSyncedAt       DateTime?
  financeSyncedById     String?
  financeSyncedBy       User?                    @relation("EstimateFinanceSyncer", fields: [financeSyncedById], references: [id])

  // Pair grouping: CLIENT + INTERNAL pair for comparison view
  role             EstimateRole @default(STANDALONE)
  estimateGroupId  String?
  pairedEstimateId String?
  sourceFileR2Key  String?
  sourceFileName   String?
  sourceFileMime   String?

  @@index([folderId])
  @@index([estimateGroupId])
  @@index([role])
  @@map("estimates")
}

/// Audit trail for delta-refine runs (Plan Stage 6.2).
/// Each refine produces a new Estimate version + a row here that captures
/// the diff against the previous version.
model EstimateRefineHistory {
  id                 String   @id @default(cuid())
  estimateId         String
  previousEstimateId String?
  refinedById        String?
  changeReason       String?
  impactedCategories Json?
  addedCount         Int      @default(0)
  removedCount       Int      @default(0)
  changedCount       Int      @default(0)
  unchangedCount     Int      @default(0)
  deltaAmount        Decimal  @default(0) @db.Decimal(14, 2)
  changedItems       Json?
  metadata           Json?
  createdAt          DateTime @default(now())

  estimate         Estimate  @relation("RefineHistoryEstimate", fields: [estimateId], references: [id], onDelete: Cascade)
  previousEstimate Estimate? @relation("RefineHistoryPrevious", fields: [previousEstimateId], references: [id], onDelete: SetNull)
  refinedBy        User?     @relation("RefineHistoryUser", fields: [refinedById], references: [id], onDelete: SetNull)

  @@index([estimateId])
  @@index([previousEstimateId])
  @@index([createdAt(sort: Desc)])
  @@map("estimate_refine_history")
}

model EstimateSection {
  id           String               @id @default(cuid())
  title        String
  sortOrder    Int                  @default(0)
  totalAmount  Decimal              @default(0) @map("total_amount") @db.Decimal(12, 2)
  estimateId   String
  items        EstimateItem[]
  estimate     Estimate             @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  stageRecords ProjectStageRecord[] @relation("EstimateSectionToStage")

  @@map("estimate_sections")
}

model EstimateItem {
  id                  String               @id @default(cuid())
  description         String
  unit                String
  quantity            Decimal              @db.Decimal(10, 3)
  unitPrice           Decimal              @db.Decimal(10, 2)
  laborRate           Decimal              @default(0) @db.Decimal(10, 2)
  laborHours          Decimal              @default(0) @db.Decimal(10, 2)
  amount              Decimal              @db.Decimal(12, 2)
  isManualOverride    Boolean              @default(false)
  sortOrder           Int                  @default(0)
  // Quantity engine metadata (Phase 3.2).
  // itemType: 'material' | 'labor' | 'equipment' | 'composite' | null (legacy).
  itemType            String?
  // engineKey: stable canonical id (e.g. 'electrical.power_cable') — null for LLM-only items.
  engineKey           String?
  // quantityFormula: human-readable trace of the formula that produced quantity.
  quantityFormula     String?
  // Price engine metadata (Stage 8 backend prep).
  // priceSource: human-readable source label, e.g. "Внутрішній каталог (Епіцентр)".
  priceSource         String?
  // priceSourceType: 'catalog' | 'prozorro' | 'scrape' | 'llm' | 'manual' | null.
  priceSourceType     String?
  // confidence: 0..1, weighted by source priority.
  confidence          Decimal?             @db.Decimal(4, 3)
  estimateId          String
  sectionId           String?
  materialId          String?
  customMarginPercent Decimal?             @db.Decimal(5, 2)
  marginAmount        Decimal              @default(0) @db.Decimal(12, 2)
  priceWithMargin     Decimal              @default(0) @db.Decimal(12, 2)
  useCustomMargin     Boolean              @default(false)
  // Cost-code axis (Phase 1.A1). Nullable; backfill from itemType + section title.
  costCodeId          String?
  costType            CostType?
  estimate            Estimate             @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  material            Material?            @relation(fields: [materialId], references: [id])
  section             EstimateSection?     @relation(fields: [sectionId], references: [id])
  costCode            CostCode?            @relation(fields: [costCodeId], references: [id], onDelete: SetNull)
  financeEntries      FinanceEntry[]
  kb2Items            KB2FormItem[]        @relation("EstimateItemKB2")
  stageRecords        ProjectStageRecord[] @relation("EstimateItemToStage")

  @@index([engineKey])
  @@index([confidence])
  @@index([costCodeId])
  @@index([costType])
  @@map("estimate_items")
}

model Material {
  id               String                  @id @default(cuid())
  name             String
  sku              String                  @unique
  category         String
  unit             String
  basePrice        Decimal                 @db.Decimal(10, 2)
  laborRate        Decimal                 @default(0) @db.Decimal(10, 2)
  markup           Decimal                 @default(0) @db.Decimal(5, 2)
  description      String?
  isActive         Boolean                 @default(true)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  estimateItems     EstimateItem[]
  inventoryItems    InventoryItem[]
  priceSnapshots    MaterialPriceSnapshot[]
  receiptLineItems  ReceiptLineItem[]       @relation("MaterialReceiptLines")
  supplierMaterials SupplierMaterial[]

  @@map("materials")
}

model LaborRate {
  id          String   @id @default(cuid())
  name        String
  category    String
  unit        String
  ratePerUnit Decimal  @db.Decimal(10, 2)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("labor_rates")
}

model Payment {
  id            String        @id @default(cuid())
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod @default(BANK_TRANSFER)
  status        PaymentStatus @default(PENDING)
  scheduledDate DateTime
  paidDate      DateTime?
  invoiceNumber String?
  notes         String?
  createdAt     DateTime      @default(now())
  projectId     String
  createdById   String
  createdBy     User          @relation(fields: [createdById], references: [id])
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// Факт руху грошей по проєктах і постійних витрат компанії.
// Окрема сутність від Payment (планування) і Estimate (кошторис).
model FinanceEntry {
  id           String             @id @default(cuid())
  occurredAt   DateTime
  kind         FinanceEntryKind   @default(FACT)
  type         FinanceEntryType
  amount       Decimal            @db.Decimal(12, 2)
  currency     String             @default("UAH")
  projectId    String?
  category     String
  subcategory  String?
  title        String
  description  String?
  counterparty String?
  isArchived   Boolean            @default(false)
  status       FinanceEntryStatus @default(DRAFT)
  approvedAt   DateTime?
  approvedById String?
  paidAt       DateTime?
  remindAt     DateTime?
  createdById  String
  updatedById  String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  folderId String?

  source         FinanceEntrySource @default(MANUAL)
  /// TRUE для авто-згенерованих записів (source != MANUAL): STAGE_AUTO,
  /// ESTIMATE_AUTO, PROJECT_BUDGET. Phase 4.3 з improvement plan —
  /// явний тег для derived-шару, дозволяє UI/RBAC/експортам відрізняти
  /// машинні записи від ручних без знання enum source.
  isDerived      Boolean            @default(false)
  estimateId     String?
  estimateItemId String?

  // Cost-code axis (Phase 1.A1). Nullable until backfill completes; existing
  // `category`/`subcategory` strings are kept untouched as the legacy axis.
  costCodeId String?
  costType   CostType?

  // Counterparty FK (Phase 1.A2). Existing `counterparty` string is kept as
  // a denormalised cache so search and legacy reads do not break.
  counterpartyId String?

  // Фірма-власник запису. Для projectless записів — єдиний спосіб scope-у.
  firmId String?

  // Прив'язка до конкретного етапу проекту (опційно). Заповнюється AI-синхронізацією
  // або вручну. Дозволяє рахувати allocatedBudget по етапу як SUM плану цього stageRecordId.
  stageRecordId String?

  /// Унікальний ключ для ідемпотентного імпорту з Telegram
  /// (формат "tg:<chatId>:<msgId>:<itemIdx>"). Дозволяє повторно
  /// запускати backfill-скрипт без створення дублікатів.
  tgImportKey String? @unique

  /// Idempotency key for FOREMAN_REPORT source. Зворотний посил на
  /// ForemanReportItem, з якого був створений цей FinanceEntry на
  /// approve. Унікальність гарантує, що повторний approve не створить дубль.
  foremanReportItemId String? @unique

  project            Project?                 @relation(fields: [projectId], references: [id], onDelete: SetNull)
  firm               Firm?                    @relation(fields: [firmId], references: [id])
  stageRecord        ProjectStageRecord?      @relation("StageFinanceEntries", fields: [stageRecordId], references: [id], onDelete: SetNull)
  createdBy          User                     @relation("FinanceEntryCreator", fields: [createdById], references: [id])
  updatedBy          User?                    @relation("FinanceEntryUpdater", fields: [updatedById], references: [id])
  approvedBy         User?                    @relation("FinanceEntryApprover", fields: [approvedById], references: [id])
  folder             Folder?                  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  estimate           Estimate?                @relation("EstimateFinanceEntries", fields: [estimateId], references: [id], onDelete: SetNull)
  estimateItem       EstimateItem?            @relation(fields: [estimateItemId], references: [id], onDelete: SetNull)
  costCode           CostCode?                @relation(fields: [costCodeId], references: [id], onDelete: SetNull)
  counterpartyEntity Counterparty?            @relation(fields: [counterpartyId], references: [id], onDelete: SetNull)
  attachments        FinanceEntryAttachment[]
  receiptScan        ReceiptScan?             @relation("FinanceEntryReceiptScan")
  priceSnapshots     MaterialPriceSnapshot[]
  timesheets         Timesheet[]              @relation("FinanceEntryTimesheet")
  kb2Form            KB2Form?                 @relation("FinanceEntryKB2")
  retentionRecord    RetentionRecord?         @relation("FinanceEntryRetention")
  foremanReportItem  ForemanReportItem?       @relation("ForemanReportItemToFinanceEntry", fields: [foremanReportItemId], references: [id], onDelete: SetNull)
  /// Phase 1 (supplier-debt): allocations що покривають частину/всю суму
  /// цього факту. Outstanding = amount − SUM(allocations.amount). Коли
  /// outstanding = 0 → status переводиться в PAID транзакційно.
  allocations        SupplierPaymentAllocation[] @relation("FinanceEntryAllocations")

  @@index([projectId, occurredAt])
  @@index([type, occurredAt])
  @@index([kind, type])
  @@index([category])
  @@index([isArchived])
  @@index([folderId])
  @@index([status])
  @@index([estimateId])
  @@index([source])
  @@index([remindAt])
  @@index([costCodeId])
  @@index([costType])
  @@index([counterpartyId])
  @@index([firmId])
  @@index([stageRecordId])
  @@map("finance_entries")
}

/// Reusable "+1 click" templates for recurring entries in system blocks
/// (Постійні витрати, Витрати офісу). Each template is scoped to a folder
/// and creates a FinanceEntry on apply.
model FinanceExpenseTemplate {
  id             String           @id @default(cuid())
  folderId       String
  name           String
  defaultAmount  Decimal          @db.Decimal(12, 2)
  type           FinanceEntryType
  category       String
  counterparty   String?
  // Counterparty FK (Phase 1.A2). Same migration story as FinanceEntry.
  counterpartyId String?
  description    String?
  emoji          String?
  sortOrder      Int              @default(0)
  isActive       Boolean          @default(true)
  createdById    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  folder             Folder        @relation(fields: [folderId], references: [id], onDelete: Cascade)
  createdBy          User          @relation("FinanceTemplateCreator", fields: [createdById], references: [id])
  counterpartyEntity Counterparty? @relation(fields: [counterpartyId], references: [id], onDelete: SetNull)

  @@index([folderId, sortOrder])
  @@index([folderId, isActive])
  @@index([counterpartyId])
  @@map("finance_expense_templates")
}

model FinanceEntryAttachment {
  id           String   @id @default(cuid())
  entryId      String
  r2Key        String
  originalName String
  mimeType     String
  size         Int
  uploadedById String
  createdAt    DateTime @default(now())

  entry      FinanceEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  uploadedBy User         @relation("FinanceAttachmentUploader", fields: [uploadedById], references: [id])

  @@index([entryId])
  @@map("finance_entry_attachments")
}

/// Звіт виконроба про витрати на конкретному проекті.
/// Виконроб (role=FOREMAN) надсилає вільний текст + опційні файли (фото/PDF/Excel),
/// AI парсить їх у ForemanReportItem-и; виконроб може редагувати DRAFT, потім submit-ить
/// → менеджер approve-ить, що матеріалізує items у FinanceEntry (kind=FACT, source=FOREMAN_REPORT).
model ForemanReport {
  id              String              @id @default(cuid())
  projectId       String
  firmId          String?
  createdById     String
  status          ForemanReportStatus @default(DRAFT)
  rawText         String?             @db.Text
  /// Дата витрати (foreman picks); за замовчуванням — день створення.
  occurredAt      DateTime
  currency        String              @default("UAH")
  /// Повний JSON-вивід AI-парсерів для аудиту (об'єднаний результат
  /// parseExpenseText + classifyExpenseImage + ocrReceiptStructured + parseExcelEstimate).
  aiResultJson    Json?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  reviewedById    String?
  rejectionReason String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  project     Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  firm        Firm?                     @relation(fields: [firmId], references: [id])
  createdBy   User                      @relation("ForemanReportCreator", fields: [createdById], references: [id])
  reviewedBy  User?                     @relation("ForemanReportReviewer", fields: [reviewedById], references: [id])
  items       ForemanReportItem[]
  attachments ForemanReportAttachment[]

  @@index([projectId])
  @@index([firmId])
  @@index([createdById])
  @@index([status])
  @@map("foreman_reports")
}

/// Окрема позиція у звіті виконроба. На approve кожна позиція стає FinanceEntry.
model ForemanReportItem {
  id         String   @id @default(cuid())
  reportId   String
  costType   CostType
  title      String
  unit       String?
  quantity   Decimal? @db.Decimal(12, 3)
  unitPrice  Decimal? @db.Decimal(12, 2)
  amount     Decimal  @db.Decimal(12, 2)
  currency   String   @default("UAH")
  /// AI-confidence (0..1). Низький → UI підсвічує для уважної перевірки.
  confidence Float?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  /// Phase 2 (supplier-debt): постачальник, з якого взято матеріал. Заповнюється
  /// AI-парсером (через resolveSupplier match по назві/ЄДРПОУ) або вручну
  /// foreman-ом / менеджером. На approve переноситься у FinanceEntry.counterpartyId.
  counterpartyId String?
  /// Сирий текст постачальника, що AI запропонував, але не змаппив на існуючу
  /// Counterparty (UI показує chip "AI запропонував: Будхата" + кнопка "Створити").
  supplierGuess  String?
  /// Phase 3: позначка "ціна зросла vs попередній чек цього постачальника".
  /// Виставляється на approve через upsertSupplierMaterial. UI показує "!" tooltip.
  priceIncreaseFlag Boolean @default(false)
  /// Попередня unitPrice цього матеріалу у цього постачальника на момент approve.
  /// Snapshot для UI tooltip ("було 200, стало 250").
  previousUnitPrice Decimal? @db.Decimal(12, 2)

  report       ForemanReport  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  counterparty Counterparty?  @relation("ForemanItemSupplier", fields: [counterpartyId], references: [id], onDelete: SetNull)
  financeEntry FinanceEntry?  @relation("ForemanReportItemToFinanceEntry")

  @@index([reportId])
  @@index([counterpartyId])
  @@map("foreman_report_items")
}

/// Довідник матеріалів конкретного постачальника. Накопичується автоматично
/// при approve foreman-report (upsertSupplierMaterial). Дає трекінг цін
/// "цемент у Будхати раніше коштував 200, тепер 250" і flag подорожчання.
///
/// nameKey — нормалізована назва (lower + trim + collapse spaces) для unique
/// у scope (counterpartyId, firmId). На рівні UI/API завжди показуємо `name`
/// (display) — оригінальний title з останнього звіту.
model SupplierMaterial {
  id             String   @id @default(cuid())
  counterpartyId String
  firmId         String
  /// Нормалізована назва (lower + trim + collapse). Ключ дедуплікації.
  nameKey        String
  /// Display name (з найсвіжішого звіту).
  name           String
  unit           String?
  lastPrice      Decimal? @db.Decimal(12, 2)
  lastSeenAt     DateTime?
  /// Опційний звʼязок з глобальним каталогом Material (якщо менеджер змаппив
  /// постачальницький матеріал на канонічний). Phase 3 не використовує — для
  /// Phase 4+ коли буде уніфіковане BoQ.
  materialId     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  counterparty Counterparty                   @relation("CounterpartyMaterials", fields: [counterpartyId], references: [id], onDelete: Cascade)
  firm         Firm                           @relation(fields: [firmId], references: [id])
  material     Material?                      @relation(fields: [materialId], references: [id], onDelete: SetNull)
  priceHistory SupplierMaterialPriceHistory[]

  @@unique([counterpartyId, nameKey])
  @@index([firmId, nameKey])
  @@index([materialId])
  @@map("supplier_materials")
}

/// Історія цін одного матеріалу одного постачальника. Записується при кожному
/// approve foreman-звіту з MATERIAL item (через upsertSupplierMaterial).
model SupplierMaterialPriceHistory {
  id                 String   @id @default(cuid())
  supplierMaterialId String
  price              Decimal  @db.Decimal(12, 2)
  unit               String?
  observedAt         DateTime
  /// Audit trail — звідки прийшла ціна.
  sourceReportId     String?
  sourceItemId       String?
  createdAt          DateTime @default(now())

  supplierMaterial SupplierMaterial @relation(fields: [supplierMaterialId], references: [id], onDelete: Cascade)

  @@index([supplierMaterialId, observedAt])
  @@map("supplier_material_price_history")
}

/// Файл, прикріплений до звіту виконроба (фото накладної, PDF, Excel).
/// На approve копіюється у FinanceEntryAttachment для КОЖНОЇ створеної FinanceEntry
/// (той самий r2Key — без копіювання blob), щоб бухгалтер бачив документ біля рядка.
model ForemanReportAttachment {
  id           String   @id @default(cuid())
  reportId     String
  r2Key        String
  originalName String
  mimeType     String
  size         Int
  uploadedById String
  createdAt    DateTime @default(now())

  report     ForemanReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  uploadedBy User          @relation("ForemanReportAttachmentUploader", fields: [uploadedById], references: [id])

  @@index([reportId])
  @@map("foreman_report_attachments")
}

