// 📄 Розпарсені кошториси з Prozorro
model ProzorroEstimateData {
  id            String   @id @default(cuid())
  tenderId      String
  tenderTitle   String
  awardedAmount Decimal  @db.Decimal(12, 2)
  datePublished DateTime

