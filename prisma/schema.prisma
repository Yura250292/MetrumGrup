model Meeting {
  id          String  @id @default(cuid())
  title       String
  description String? @db.Text

  /// Опціональний звʼязок з проєктом. Раніше був required, прибрали —
  /// наради живуть у власній «папці нарад» (folderId) і не привʼязуються
  /// до проєктів автоматично.
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  /// Фірма-власник наради. Скоуп без проєкту (бо projectId тепер опц.).
  /// Заповнюється з активного firm-scope при створенні.
  firmId String?
  firm   Firm?   @relation(fields: [firmId], references: [id])

  createdById String
  createdBy   User   @relation("MeetingCreator", fields: [createdById], references: [id])

  audioR2Key      String?
  audioUrl        String?
  audioMimeType   String?
  audioDurationMs Int?
  audioSizeBytes  Int?

  status          MeetingStatus @default(DRAFT)
  transcript      String?       @db.Text
  summary         String?       @db.Text
  structured      Json?
  aiModelUsed     String?
  aiTokensUsed    Int?
  processingError String?       @db.Text

  /// AssemblyAI-збагачені сигнали з аудіо (etap 1 у синергії з GPT-4o):
  /// Скільки спікерів модель розпізнала.
  speakerCount Int?
  /// Сирі utterance-и з лейблами (Speaker A/B/...) і таймстемпами.
  /// Структура: [{ speaker: "A", start: 1230, end: 4560, text: "..." }, ...]
  utterances   Json?
  /// AssemblyAI entity_detection — імена, суми, дати, локації, організації.
  /// Структура: [{ entity_type: "person_name", text: "Любовь Николаевна", start, end }, ...]
  entities     Json?
  /// AssemblyAI auto_chapters — розбивка на тематичні розділи з summary.
  chapters     Json?
  /// Який сервіс зробив транскрипт (для діагностики/міграції).
  transcribeProvider String? // 'assemblyai' | 'whisper'

  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId])
  @@index([createdById])
  @@index([recordedAt])
  @@index([folderId])
  @@index([firmId])
  @@map("meetings")
}

enum MeetingStatus {
  DRAFT
  UPLOADED
  TRANSCRIBING
  TRANSCRIBED
  SUMMARIZING
  READY
  FAILED
}

/// Тип відстрочки/бронювання військовозобовʼязаного.
/// NONE — відсутня (не підлягає бронюванню/не виплачується).
enum DeferralType {
  NONE
  RESERVATION
  DEFERMENT
}

/// Тип зайнятості співробітника.
enum EmploymentType {
  FULL
  PART
  CONTRACT
}

/// Історія ЗП співробітника. Активний період — той, у якого effectiveTo IS NULL
/// або effectiveTo > now. На UI HR не бачить цих записів. Кеш поточного значення
/// тримається у Employee.salaryAmount (для legacy payroll/forecast), але джерело
/// правди — цей рядок.
model EmployeeSalary {
  id            String    @id @default(cuid())
  employeeId    String
  employee      Employee  @relation("EmployeeSalaryHistory", fields: [employeeId], references: [id], onDelete: Cascade)
  /// Оклад — базова ставка ЗП.
  baseSalary    Decimal   @db.Decimal(12, 2)
  /// Офіційна частина ЗП — входить в оклад (інформативно).
  officialPart  Decimal?  @db.Decimal(12, 2)
  /// Коефіцієнт/надбавка/премія до окладу.
  coefficient   Decimal   @default(0) @db.Decimal(12, 2)
  /// Текстове пояснення (за що, як рахується).
  description   String?
  /// З якого числа діє цей запис.
  effectiveFrom DateTime
  /// До якого числа діяв (включно). null = досі діючий.
  effectiveTo   DateTime?
  currency      String    @default("UAH")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([employeeId, effectiveFrom])
  @@map("employee_salaries")
}

model Employee {
  id            String           @id @default(cuid())
  /// Збірне відображення (= "lastName firstName middleName"). Тримається
  /// синхронним з частинами імені на API-боці; лишилось для старого пошуку.
  fullName      String
  /// Прізвище.
  lastName      String?
  /// Імʼя.
  firstName     String?
  /// По-батькові.
  middleName    String?
  phone         String?
  email         String?
  position      String?
  birthDate     DateTime?
  /// Deprecated: видалено з UI; колонку лишили для історичних значень.
  residence     String?
  /// Deprecated: видалено з UI; колонку лишили для історичних значень.
  maritalStatus String?
  hiredAt       DateTime?
  terminatedAt  DateTime?
  notes         String?
  isActive      Boolean          @default(true)
  /// Тип зайнятості (Повна / Неповна / Договір).
  employmentType EmploymentType  @default(FULL)
  /// Ставка зайнятості (1.0 = ставка, 0.5 = пів-ставки тощо).
  employmentRate Decimal         @default(1.0) @db.Decimal(4, 2)
  /// Структурний підрозділ.
  departmentId  String?
  department    Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  /// Тип відстрочки/бронювання.
  deferralType  DeferralType     @default(NONE)
  /// До коли діє відстрочка/бронювання.
  deferralUntil DateTime?
  userId        String?          @unique
  user          User?            @relation("EmployeeUser", fields: [userId], references: [id], onDelete: SetNull)
  timesheets    Timesheet[]      @relation("EmployeeTimesheets")
  salaries      EmployeeSalary[] @relation("EmployeeSalaryHistory")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([isActive])
  @@index([fullName])
  @@index([departmentId])
  @@map("employees")
}

/// Daily labor record. Either employeeId OR workerId must be set (xor),
/// enforced at the API level since Prisma does not support OR-required.
/// Used by payroll/run (mode=timesheet) to allocate labor cost to projects
/// and cost-codes; the resulting FinanceEntry is linked back via financeEntryId.
model Timesheet {
  id             String    @id @default(cuid())
  /// Internal staff (Employee model). Mutually exclusive with workerId.
  employeeId     String?
  /// Subcontractor / crew member (Worker model). Mutually exclusive with employeeId.
  workerId       String?
  projectId      String
  costCodeId     String?
  costType       CostType?
  date           DateTime  @db.Date
  hours          Decimal   @db.Decimal(5, 2)
  hourlyRate     Decimal   @db.Decimal(10, 2)
  /// Denormalised hours × hourlyRate; kept for fast aggregation. Refresh on update.
  amount         Decimal   @db.Decimal(12, 2)
  notes          String?
  approvedAt     DateTime?
  approvedById   String?
  /// Set when payroll/run rolls this row into a FinanceEntry. SetNull when entry is deleted.
  financeEntryId String?   @unique

  createdById String
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee     Employee?     @relation("EmployeeTimesheets", fields: [employeeId], references: [id], onDelete: Cascade)
  worker       Worker?       @relation("WorkerTimesheets", fields: [workerId], references: [id], onDelete: Cascade)
  project      Project       @relation("ProjectTimesheets", fields: [projectId], references: [id], onDelete: Cascade)
  costCode     CostCode?     @relation("CostCodeTimesheets", fields: [costCodeId], references: [id], onDelete: SetNull)
  approvedBy   User?         @relation("TimesheetApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  createdBy    User          @relation("TimesheetCreator", fields: [createdById], references: [id])
  updatedBy    User?         @relation("TimesheetUpdater", fields: [updatedById], references: [id])
  financeEntry FinanceEntry? @relation("FinanceEntryTimesheet", fields: [financeEntryId], references: [id], onDelete: SetNull)

  @@index([projectId, date])
  @@index([employeeId, date])
  @@index([workerId, date])
  @@index([costCodeId])
  @@index([approvedAt])
  @@map("timesheets")
}

enum CounterpartyType {
  LEGAL
  INDIVIDUAL
  FOP
}

/// Роль контрагента у бізнес-процесах. Масив, бо одна юрособа може водночас бути
/// клієнтом і субпідрядником (типово в будівництві). Backfill заповнює існуючі
/// рядки на основі того, де вони згадуються (Project.clientCounterpartyId →
/// CLIENT, FinanceEntry.type=EXPENSE → SUPPLIER).
enum CounterpartyRole {
  CLIENT
  SUPPLIER
  CONTRACTOR
  EMPLOYEE
  OTHER
}

/// Lifecycle платежу постачальнику.
/// POSTED — платіж проведено, allocations live, FinanceEntry оновлено.
/// VOIDED — платіж скасовано, allocations видалено, FE статуси повернуті.
enum SupplierPaymentStatus {
  POSTED
  VOIDED
}

model Counterparty {
  id        String           @id @default(cuid())
  name      String
  type      CounterpartyType @default(LEGAL)
  /// Ролі у системі. Порожній масив = OTHER (не використовується активно).
  /// Фільтрація списків постачальників відбувається через `roles has SUPPLIER`.
  roles     CounterpartyRole[] @default([])
  taxId     String?
  /// EDRPOU (legal) / RNOKPP (FOP, individual) — Ukrainian tax identifier.
  edrpou    String?
  /// Bank account for outgoing payments (display-only, no validation).
  iban      String?
  /// Whether the counterparty is a VAT payer (платник ПДВ).
  vatPayer  Boolean          @default(false)
  phone     String?
  email     String?
  address   String?
  notes     String?
  isActive  Boolean          @default(true)
  /// Default payment terms (днів) для SUPPLIER. Використовується UI для прогнозу
  /// "коли треба заплатити". null — без терміну.
  defaultPaymentTermsDays Int?
  /// Підказка для UI: який метод оплати зазвичай використовується.
  preferredPaymentMethod  PaymentMethod?
  /// Фірма-власник (Group / Studio). Контрагенти ізольовані між фірмами;
  /// один SUPPLIER може існувати окремо в Group і в Studio (різні рядки).
  firmId    String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  firm             Firm?                    @relation(fields: [firmId], references: [id])
  financeEntries   FinanceEntry[]
  financeTemplates FinanceExpenseTemplate[]
  kb2Forms         KB2Form[]                @relation("KB2FormCounterparty")
  kb3Forms         KB3Form[]                @relation("KB3FormCounterparty")
  /// Проекти, де цей контрагент виступає клієнтом (Project.clientCounterpartyId).
  clientProjects     Project[]              @relation("ProjectClientCounterparty")
  supplierPayments   SupplierPayment[]
  foremanReportItems ForemanReportItem[]    @relation("ForemanItemSupplier")
  supplierMaterials  SupplierMaterial[]     @relation("CounterpartyMaterials")

  @@index([isActive])
  @@index([type])
  @@index([name])
  @@index([firmId])
  @@index([roles], type: Gin)
  @@map("counterparties")
}

/// Платіж постачальнику. Сума розкидається FIFO по несплачених FinanceEntry
/// цього постачальника через SupplierPaymentAllocation. Один платіж може
/// покривати декілька несплачених фактів (типовий кейс: постачальник дав
/// матеріал на 3 проєкти, ми платимо одну суму що розподіляється).
///
/// Інваріант 1: SUM(allocations.amount) <= SupplierPayment.amount.
///   Залишок (overpayment) лишається unallocated до майбутнього факту.
/// Інваріант 2: SUM(allocations[forEntryId].amount) <= FinanceEntry.amount.
///   Гарантовано унікальним індексом + транзакційною FIFO логікою.
/// Multi-firm: counterpartyId.firmId має співпадати з SupplierPayment.firmId
///   (валідація в API).
model SupplierPayment {
  id              String                @id @default(cuid())
  counterpartyId  String
  firmId          String
  /// Опційно: якщо платіж зроблено в межах одного проєкту, FIFO обмежиться
  /// фактами цього проєкту. Null = розподіл по всіх фактах постачальника.
  projectId       String?
  amount          Decimal               @db.Decimal(14, 2)
  currency        String                @default("UAH")
  occurredAt      DateTime
  method          PaymentMethod         @default(BANK_TRANSFER)
  /// Номер платіжки / чека / тощо (вільний текст для аудиту).
  reference       String?
  notes           String?
  status          SupplierPaymentStatus @default(POSTED)
  voidedAt        DateTime?
  voidedById      String?
  voidReason      String?
  createdById     String
  /// Idempotency-Key з UI/API. Захищає від подвійного submit (ретрай за
  /// мережевих помилок створює один SupplierPayment, не два).
  idempotencyKey  String?               @unique
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  counterparty Counterparty                @relation(fields: [counterpartyId], references: [id])
  firm         Firm                        @relation(fields: [firmId], references: [id])
  project      Project?                    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy    User                        @relation("SupplierPaymentCreator", fields: [createdById], references: [id])
  voidedBy     User?                       @relation("SupplierPaymentVoider", fields: [voidedById], references: [id])
  allocations  SupplierPaymentAllocation[]

  @@index([counterpartyId, occurredAt])
  @@index([firmId, occurredAt])
  @@index([projectId])
  @@index([status])
  @@map("supplier_payments")
}

/// Розкидка платежу по конкретному FinanceEntry. Сума на пару (payment, entry)
/// унікальна — це idempotency-замок на алгоритм FIFO (повторний прогон не задвоїть
/// рядок). При void платежу всі його allocations видаляються каскадом, а статуси
/// зачеплених FinanceEntry перераховуються (PAID → APPROVED) у тій же транзакції.
model SupplierPaymentAllocation {
  id             String   @id @default(cuid())
  paymentId      String
  financeEntryId String
  amount         Decimal  @db.Decimal(14, 2)
  createdAt      DateTime @default(now())

  payment      SupplierPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  financeEntry FinanceEntry    @relation("FinanceEntryAllocations", fields: [financeEntryId], references: [id], onDelete: Cascade)

  @@unique([paymentId, financeEntryId])
  @@index([financeEntryId])
  @@map("supplier_payment_allocations")
}

enum KB2Status {
  DRAFT
  ISSUED
  SIGNED
  CANCELLED
}

enum KB3Status {
  DRAFT
  ISSUED
  SIGNED
  CANCELLED
}

enum RetentionStatus {
  HELD
  RELEASED
  CANCELLED
}

/// КБ-2в — Акт виконаних будівельних робіт (UA standard, ДБН Д.1.1-1:2013).
/// Snapshot of selected estimate items × % completion for a billing period.
/// Items copied at form creation so retroactive estimate edits don't mutate
/// historical acts.
model KB2Form {
  id               String    @id @default(cuid())
  projectId        String
  estimateId       String?
  /// Customer (we bill them) or contractor (they bill us). For most KB-2в it's the project's client.
  counterpartyId   String?
  number           String    @unique
  periodFrom       DateTime
  periodTo         DateTime
  /// Σ items.amount before retention.
  totalAmount      Decimal   @default(0) @db.Decimal(14, 2)
  /// 0–100. Default project.retentionPercent, overridable per form.
  retentionPercent Decimal   @default(0) @db.Decimal(5, 2)
  retentionAmount  Decimal   @default(0) @db.Decimal(14, 2)
  /// = totalAmount − retentionAmount.
  netPayable       Decimal   @default(0) @db.Decimal(14, 2)
  status           KB2Status @default(DRAFT)
  notes            String?
  pdfR2Key         String?
  issuedAt         DateTime?
  signedAt         DateTime?
  cancelledAt      DateTime?
  approvedById     String?
  /// FinanceEntry created on SIGNED transition (INCOME PLAN/FACT for net payable).
  financeEntryId   String?   @unique

  /// Roll-up into a parent KB-3 (period summary). Nullable so KB-2 can stand alone.
  kb3FormId String?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project      Project           @relation("ProjectKB2Forms", fields: [projectId], references: [id], onDelete: Cascade)
  estimate     Estimate?         @relation("EstimateKB2Forms", fields: [estimateId], references: [id], onDelete: SetNull)
  counterparty Counterparty?     @relation("KB2FormCounterparty", fields: [counterpartyId], references: [id], onDelete: SetNull)
  financeEntry FinanceEntry?     @relation("FinanceEntryKB2", fields: [financeEntryId], references: [id], onDelete: SetNull)
  kb3Form      KB3Form?          @relation("KB3KB2Forms", fields: [kb3FormId], references: [id], onDelete: SetNull)
  createdBy    User              @relation("KB2FormCreator", fields: [createdById], references: [id])
  approvedBy   User?             @relation("KB2FormApprover", fields: [approvedById], references: [id])
  items        KB2FormItem[]
  retentions   RetentionRecord[]

  @@index([projectId, periodTo])
  @@index([counterpartyId])
  @@index([status])
  @@index([kb3FormId])
  @@map("kb2_forms")
}

model KB2FormItem {
  id                String    @id @default(cuid())
  formId            String
  /// Optional traceability back to the source line. SetNull on estimate edit.
  estimateItemId    String?
  /// Frozen description from estimate at time of form creation.
  description       String
  unit              String
  /// Total qty per estimate (full scope).
  totalQty          Decimal   @db.Decimal(12, 3)
  unitPrice         Decimal   @db.Decimal(12, 2)
  /// What we're invoicing for in this period (cumulative or delta — operator-defined).
  completedQty      Decimal   @db.Decimal(12, 3)
  amount            Decimal   @db.Decimal(14, 2)
  /// % completion as of the form (0–100). Calculated client-side; stored for the PDF.
  completionPercent Decimal?  @db.Decimal(5, 2)
  costCodeId        String?
  costType          CostType?
  sortOrder         Int       @default(0)

  form         KB2Form       @relation(fields: [formId], references: [id], onDelete: Cascade)
  estimateItem EstimateItem? @relation("EstimateItemKB2", fields: [estimateItemId], references: [id], onDelete: SetNull)
  costCode     CostCode?     @relation("CostCodeKB2", fields: [costCodeId], references: [id], onDelete: SetNull)

  @@index([formId, sortOrder])
  @@index([estimateItemId])
  @@map("kb2_form_items")
}

/// КБ-3 — Довідка про вартість виконаних будівельних робіт. Aggregator over KB-2в.
model KB3Form {
  id             String    @id @default(cuid())
  projectId      String
  counterpartyId String?
  number         String    @unique
  periodFrom     DateTime
  periodTo       DateTime
  totalAmount    Decimal   @default(0) @db.Decimal(14, 2)
  status         KB3Status @default(DRAFT)
  notes          String?
  pdfR2Key       String?
  issuedAt       DateTime?
  signedAt       DateTime?
  approvedById   String?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project      Project       @relation("ProjectKB3Forms", fields: [projectId], references: [id], onDelete: Cascade)
  counterparty Counterparty? @relation("KB3FormCounterparty", fields: [counterpartyId], references: [id], onDelete: SetNull)
  createdBy    User          @relation("KB3FormCreator", fields: [createdById], references: [id])
  approvedBy   User?         @relation("KB3FormApprover", fields: [approvedById], references: [id])
  kb2Forms     KB2Form[]     @relation("KB3KB2Forms")

  @@index([projectId, periodTo])
  @@index([status])
  @@map("kb3_forms")
}

/// Retention (гарантійне утримання). Auto-created when a KB-2 is signed and
/// retentionPercent > 0. Released when releaseDate hits or operator marks paid;
/// release creates a FinanceEntry FACT EXPENSE that closes the obligation.
model RetentionRecord {
  id                     String          @id @default(cuid())
  kb2FormId              String
  amount                 Decimal         @db.Decimal(14, 2)
  /// Default = project end date + 12 months; customisable per form.
  releaseDate            DateTime
  releasedAt             DateTime?
  releasedFinanceEntryId String?         @unique
  status                 RetentionStatus @default(HELD)
  notes                  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  form                 KB2Form       @relation(fields: [kb2FormId], references: [id], onDelete: Cascade)
  releasedFinanceEntry FinanceEntry? @relation("FinanceEntryRetention", fields: [releasedFinanceEntryId], references: [id], onDelete: SetNull)

  @@index([kb2FormId])
  @@index([status, releaseDate])
  @@map("retention_records")
}

enum CostType {
  MATERIAL
  LABOR
  SUBCONTRACT
  EQUIPMENT
  OVERHEAD
  OTHER
}

/// Cost code tree (стаття витрат). Two-tier or three-tier hierarchy used to roll
/// up plan, commitments and actuals into the same axis across estimates,
/// finance entries and timesheets. Codes are globally unique strings like
/// "03.1" or "07.2.1" so they can be referenced by import/export tools.
model CostCode {
  id              String    @id @default(cuid())
  code            String    @unique
  name            String
  parentId        String?
  defaultCostType CostType?
  isSystem        Boolean   @default(false)
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  parent         CostCode?      @relation("CostCodeTree", fields: [parentId], references: [id], onDelete: Restrict)
  children       CostCode[]     @relation("CostCodeTree")
  financeEntries FinanceEntry[]
  estimateItems  EstimateItem[]
  timesheets     Timesheet[]    @relation("CostCodeTimesheets")
  kb2Items       KB2FormItem[]  @relation("CostCodeKB2")

  @@index([parentId, sortOrder])
  @@index([isActive])
  @@map("cost_codes")
}

// Receipt scan workflow: manager scans an invoice for a project, an approver
// (SUPER_ADMIN/MANAGER/FINANCIER) confirms, after which materials are posted to
// the project's warehouse and prices are stored as MaterialPriceSnapshot.
model ReceiptScan {
  id               String            @id @default(cuid())
  projectId        String
  warehouseId      String?
  status           ReceiptScanStatus @default(PENDING)
  source           ReceiptScanSource @default(WEB)
  supplier         String?
  documentDate     DateTime?
  totalAmount      Decimal?          @db.Decimal(12, 2)
  currency         String            @default("UAH")
  ocrText          String?           @db.Text
  ocrJson          Json?
  fileR2Key        String?
  fileMimeType     String?
  fileOriginalName String?
  notes            String?
  rejectionReason  String?
  createdById      String
  approvedById     String?
  approvedAt       DateTime?
  financeEntryId   String?           @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  project        Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  warehouse      Warehouse?              @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  createdBy      User                    @relation("ReceiptScanCreator", fields: [createdById], references: [id])
  approvedBy     User?                   @relation("ReceiptScanApprover", fields: [approvedById], references: [id])
  financeEntry   FinanceEntry?           @relation("FinanceEntryReceiptScan", fields: [financeEntryId], references: [id], onDelete: SetNull)
  lineItems      ReceiptLineItem[]
  priceSnapshots MaterialPriceSnapshot[]

  @@index([projectId, status])
  @@index([status, createdAt])
  @@map("receipt_scans")
}

model ReceiptLineItem {
  id                String                @id @default(cuid())
  scanId            String
  rawName           String
  rawUnit           String?
  quantity          Decimal               @db.Decimal(10, 3)
  unitPrice         Decimal               @db.Decimal(10, 2)
  totalPrice        Decimal?              @db.Decimal(12, 2)
  status            ReceiptLineItemStatus @default(UNMATCHED)
  matchedMaterialId String?
  matchConfidence   Float?
  proposedSku       String?
  proposedCategory  String?
  notes             String?
  sortOrder         Int                   @default(0)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  scan            ReceiptScan            @relation(fields: [scanId], references: [id], onDelete: Cascade)
  matchedMaterial Material?              @relation("MaterialReceiptLines", fields: [matchedMaterialId], references: [id], onDelete: SetNull)
  priceSnapshot   MaterialPriceSnapshot?

  @@index([scanId])
  @@index([matchedMaterialId])
  @@map("receipt_line_items")
}

// Per-purchase price record. Future estimates can pull last/avg/min price per
// material per supplier without losing the history when Material.basePrice changes.
model MaterialPriceSnapshot {
  id                String              @id @default(cuid())
  materialId        String
  price             Decimal             @db.Decimal(10, 2)
  unit              String
  quantity          Decimal?            @db.Decimal(10, 3)
  supplier          String?
  source            PriceSnapshotSource @default(RECEIPT_SCAN)
  occurredAt        DateTime
  projectId         String?
  warehouseId       String?
  receiptScanId     String?
  receiptLineItemId String?             @unique
  financeEntryId    String?
  createdById       String
  createdAt         DateTime            @default(now())

  material        Material         @relation(fields: [materialId], references: [id], onDelete: Cascade)
  project         Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  warehouse       Warehouse?       @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  receiptScan     ReceiptScan?     @relation(fields: [receiptScanId], references: [id], onDelete: SetNull)
  receiptLineItem ReceiptLineItem? @relation(fields: [receiptLineItemId], references: [id], onDelete: SetNull)
  financeEntry    FinanceEntry?    @relation(fields: [financeEntryId], references: [id], onDelete: SetNull)
  createdBy       User             @relation("PriceSnapshotCreator", fields: [createdById], references: [id])

  @@index([materialId, occurredAt])
  @@index([projectId, occurredAt])
  @@index([source])
  @@map("material_price_snapshots")
}

enum ReceiptScanStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ReceiptScanSource {
  WEB
  TELEGRAM
}

enum ReceiptLineItemStatus {
  MATCHED
  SUGGESTED
  UNMATCHED
  CONFIRMED
  CREATE_NEW
  SKIPPED
}

enum PriceSnapshotSource {
  RECEIPT_SCAN
  MANUAL
  ESTIMATE
  IMPORT
}

/// Owner AI chat persistence — кожна conversation це сесія діалогу
/// власника з асистентом. Дозволяє повернутись до минулих запитів.
model OwnerConversation {
  id           String    @id @default(cuid())
  userId       String
  /// firmId на момент початку розмови (фіксується для контексту).
  firmId       String?
  title        String    @default("Нова розмова")
  /// Кількість повідомлень — для швидкого відображення списку.
  messageCount Int       @default(0)
  /// Поки розмова в роботі (стрімінг) — true. Після завершення — false.
  isActive     Boolean   @default(false)
  /// Закріплено зверху списку (як starred у Telegram/Slack).
  isPinned     Boolean   @default(false)
  /// Дата закріплення — щоб сортувати закріплені окремо за recency.
  pinnedAt     DateTime?
  /// Опційно: розмова належить теці (для групування у sidebar).
  folderId     String?
  /// Токен для read-only public-share лінку. NULL = не shared.
  shareToken   String?   @unique
  shareTokenAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user     User               @relation("OwnerConversationUser", fields: [userId], references: [id], onDelete: Cascade)
  folder   OwnerChatFolder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  messages OwnerChatMessage[]

  @@index([userId, updatedAt])
  @@index([userId, isPinned, pinnedAt])
  @@index([folderId])
  @@index([shareToken])
  @@map("owner_conversations")
}

/// Тека для групування розмов власника. Плоский список (без вкладеності) —
/// достатньо для перших користувачів.
model OwnerChatFolder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User                @relation("OwnerChatFolderUser", fields: [userId], references: [id], onDelete: Cascade)
  conversations OwnerConversation[]

  @@index([userId, sortOrder])
  @@map("owner_chat_folders")
}

enum OwnerChatRole {
  user
  assistant
}

model OwnerChatMessage {
  id             String        @id @default(cuid())
  conversationId String
  role           OwnerChatRole
  /// Сирий markdown контент.
  content        String        @db.Text
  /// Tool calls/results як JSON масив для відновлення UI.
  toolCallsJson  Json?
  /// Закладка — для збереження важливих моментів. Видно у sidebar tab "Закладки".
  isBookmarked   Boolean       @default(false)
  createdAt      DateTime      @default(now())

  conversation OwnerConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([isBookmarked])
  @@map("owner_chat_messages")
}
