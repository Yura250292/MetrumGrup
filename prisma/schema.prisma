  documentFormat String // "application/pdf", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"

  parsedAt    DateTime @default(now())
  parseStatus String   @default("success") // "success", "partial", "failed"
  parseErrors Json? // Помилки парсингу якщо були

