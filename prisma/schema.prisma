generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                 @id @default(cuid())
  email              String                 @unique
  password           String
  name               String
  phone              String?
  avatar             String?
  role               Role                   @default(CLIENT)
  isActive           Boolean                @default(true)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  auditLogs          AuditLog[]
  createdEstimates   Estimate[]             @relation("EstimateCreator")
  engineerReviews    Estimate[]             @relation("EngineerReviews")
  financeReviews     Estimate[]             @relation("FinanceReviews")
  financialTemplates FinancialTemplate[]    @relation("TemplateCreator")
  inventoryTx        InventoryTransaction[]
  newsArticles       NewsArticle[]
  notifications      Notification[]
  payments           Payment[]
  photoReports       PhotoReport[]
  projectFiles       ProjectFile[]
  clientProjects     Project[]              @relation("ClientProjects")
  managedProjects    Project[]              @relation("ManagerProjects")

  @@map("users")
}

model Project {
  id                String                 @id @default(cuid())
  title             String
  slug              String                 @unique
  description       String?
  address           String?
  status            ProjectStatus          @default(DRAFT)
  currentStage      ProjectStage           @default(DESIGN)
  stageProgress     Int                    @default(0)
  totalBudget       Decimal                @default(0) @db.Decimal(12, 2)
  totalPaid         Decimal                @default(0) @db.Decimal(12, 2)
  startDate         DateTime?
  expectedEndDate   DateTime?
  actualEndDate     DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  clientId          String
  managerId         String?
  auditLogs         AuditLog[]
  completionActs    CompletionAct[]
  crewAssignments   CrewAssignment[]
  equipmentAssigned Equipment[]
  estimates         Estimate[]
  inventoryTx       InventoryTransaction[]
  payments          Payment[]
  photoReports      PhotoReport[]
  files             ProjectFile[]
  stages            ProjectStageRecord[]
  client            User                   @relation("ClientProjects", fields: [clientId], references: [id])
  manager           User?                  @relation("ManagerProjects", fields: [managerId], references: [id])

  @@map("projects")
}

model ProjectStageRecord {
  id        String       @id @default(cuid())
  stage     ProjectStage
  status    StageStatus  @default(PENDING)
  progress  Int          @default(0)
  notes     String?
  startDate DateTime?
  endDate   DateTime?
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  projectId String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, stage])
  @@map("project_stage_records")
}

model Estimate {
  id                    String            @id @default(cuid())
  number                String            @unique
  title                 String
  description           String?
  status                EstimateStatus    @default(DRAFT)
  version               Int               @default(1)
  totalMaterials        Decimal           @default(0) @db.Decimal(12, 2)
  totalLabor            Decimal           @default(0) @db.Decimal(12, 2)
  totalOverhead         Decimal           @default(0) @db.Decimal(12, 2)
  totalAmount           Decimal           @default(0) @db.Decimal(12, 2)
  discount              Decimal           @default(0) @db.Decimal(5, 2)
  finalAmount           Decimal           @default(0) @db.Decimal(12, 2)
  notes                 String?
  sentAt                DateTime?
  approvedAt            DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  projectId             String
  createdById           String
  engineerNotes         String?
  engineerReviewedAt    DateTime?
  engineerReviewedById  String?
  financeNotes          String?
  financeReviewedAt     DateTime?
  financeReviewedById   String?
  finalClientPrice      Decimal           @default(0) @db.Decimal(12, 2)
  profitAmount          Decimal           @default(0) @db.Decimal(12, 2)
  profitMarginLabor     Decimal?          @db.Decimal(5, 2)
  profitMarginMaterials Decimal?          @db.Decimal(5, 2)
  profitMarginOverall   Decimal           @default(20) @db.Decimal(5, 2)
  taxAmount             Decimal           @default(0) @db.Decimal(12, 2)
  taxRate               Decimal           @default(0) @db.Decimal(5, 2)
  taxationType          TaxationType?
  logisticsCost         Decimal           @default(0) @db.Decimal(12, 2)
  pdvAmount             Decimal           @default(0) @db.Decimal(12, 2)
  esvAmount             Decimal           @default(0) @db.Decimal(12, 2)
  militaryTaxAmount     Decimal           @default(0) @db.Decimal(12, 2)
  profitTaxAmount       Decimal           @default(0) @db.Decimal(12, 2)
  unifiedTaxAmount      Decimal           @default(0) @db.Decimal(12, 2)
  pdfoAmount            Decimal           @default(0) @db.Decimal(12, 2)
  taxCalculationDetails Json?
  taxCalculatedAt       DateTime?
  items                 EstimateItem[]
  sections              EstimateSection[]
  createdBy             User              @relation("EstimateCreator", fields: [createdById], references: [id])
  engineerReviewedBy    User?             @relation("EngineerReviews", fields: [engineerReviewedById], references: [id])
  financeReviewedBy     User?             @relation("FinanceReviews", fields: [financeReviewedById], references: [id])
  project               Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("estimates")
}

model EstimateSection {
  id         String         @id @default(cuid())
  title      String
  sortOrder  Int            @default(0)
  estimateId String
  items      EstimateItem[]
  estimate   Estimate       @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@map("estimate_sections")
}

model EstimateItem {
  id                  String           @id @default(cuid())
  description         String
  unit                String
  quantity            Decimal          @db.Decimal(10, 3)
  unitPrice           Decimal          @db.Decimal(10, 2)
  laborRate           Decimal          @default(0) @db.Decimal(10, 2)
  laborHours          Decimal          @default(0) @db.Decimal(10, 2)
  amount              Decimal          @db.Decimal(12, 2)
  isManualOverride    Boolean          @default(false)
  sortOrder           Int              @default(0)
  estimateId          String
  sectionId           String?
  materialId          String?
  customMarginPercent Decimal?         @db.Decimal(5, 2)
  marginAmount        Decimal          @default(0) @db.Decimal(12, 2)
  priceWithMargin     Decimal          @default(0) @db.Decimal(12, 2)
  useCustomMargin     Boolean          @default(false)
  estimate            Estimate         @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  material            Material?        @relation(fields: [materialId], references: [id])
  section             EstimateSection? @relation(fields: [sectionId], references: [id])

  @@map("estimate_items")
}

model Material {
  id             String          @id @default(cuid())
  name           String
  sku            String          @unique
  category       String
  unit           String
  basePrice      Decimal         @db.Decimal(10, 2)
  laborRate      Decimal         @default(0) @db.Decimal(10, 2)
  markup         Decimal         @default(0) @db.Decimal(5, 2)
  description    String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  estimateItems  EstimateItem[]
  inventoryItems InventoryItem[]

  @@map("materials")
}

model LaborRate {
  id          String   @id @default(cuid())
  name        String
  category    String
  unit        String
  ratePerUnit Decimal  @db.Decimal(10, 2)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("labor_rates")
}

model Payment {
  id            String        @id @default(cuid())
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod @default(BANK_TRANSFER)
  status        PaymentStatus @default(PENDING)
  scheduledDate DateTime
  paidDate      DateTime?
  invoiceNumber String?
  notes         String?
  createdAt     DateTime      @default(now())
  projectId     String
  createdById   String
  createdBy     User          @relation(fields: [createdById], references: [id])
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model CompletionAct {
  id             String    @id @default(cuid())
  number         String
  title          String
  description    String?
  amount         Decimal   @db.Decimal(12, 2)
  fileUrl        String?
  signedByClient Boolean   @default(false)
  signedAt       DateTime?
  createdAt      DateTime  @default(now())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("completion_acts")
}

model PhotoReport {
  id          String             @id @default(cuid())
  title       String
  description String?
  stage       ProjectStage
  createdAt   DateTime           @default(now())
  projectId   String
  createdById String
  images      PhotoReportImage[]
  createdBy   User               @relation(fields: [createdById], references: [id])
  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("photo_reports")
}

model PhotoReportImage {
  id            String      @id @default(cuid())
  url           String
  thumbnailUrl  String?
  caption       String?
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  photoReportId String
  photoReport   PhotoReport @relation(fields: [photoReportId], references: [id], onDelete: Cascade)

  @@map("photo_report_images")
}

model ProjectFile {
  id           String   @id @default(cuid())
  type         FileType
  name         String
  url          String
  size         Int
  mimeType     String
  createdAt    DateTime @default(now())
  projectId    String
  uploadedById String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])

  @@map("project_files")
}

model Equipment {
  id               String          @id @default(cuid())
  name             String
  type             String
  serialNumber     String?         @unique
  status           EquipmentStatus @default(AVAILABLE)
  currentLocation  String?
  purchaseDate     DateTime?
  purchaseCost     Decimal?        @db.Decimal(12, 2)
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  currentProjectId String?
  currentProject   Project?        @relation(fields: [currentProjectId], references: [id])

  @@map("equipment")
}

model Warehouse {
  id             String          @id @default(cuid())
  name           String
  address        String?
  isDefault      Boolean         @default(false)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  inventoryItems InventoryItem[]

  @@map("warehouses")
}

model InventoryItem {
  id              String                 @id @default(cuid())
  quantity        Decimal                @default(0) @db.Decimal(10, 3)
  minQuantity     Decimal                @default(0) @db.Decimal(10, 3)
  maxQuantity     Decimal?               @db.Decimal(10, 3)
  lastRestockedAt DateTime?
  updatedAt       DateTime               @updatedAt
  materialId      String
  warehouseId     String
  material        Material               @relation(fields: [materialId], references: [id])
  warehouse       Warehouse              @relation(fields: [warehouseId], references: [id])
  transactions    InventoryTransaction[]

  @@unique([materialId, warehouseId])
  @@map("inventory_items")
}

model InventoryTransaction {
  id              String                   @id @default(cuid())
  type            InventoryTransactionType
  quantity        Decimal                  @db.Decimal(10, 3)
  notes           String?
  createdAt       DateTime                 @default(now())
  inventoryItemId String
  projectId       String?
  createdById     String
  createdBy       User                     @relation(fields: [createdById], references: [id])
  inventoryItem   InventoryItem            @relation(fields: [inventoryItemId], references: [id])
  project         Project?                 @relation(fields: [projectId], references: [id])

  @@map("inventory_transactions")
}

model Worker {
  id              String           @id @default(cuid())
  name            String
  phone           String?
  specialty       String
  dailyRate       Decimal          @db.Decimal(10, 2)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  crewAssignments CrewAssignment[]

  @@map("workers")
}

model CrewAssignment {
  id        String    @id @default(cuid())
  role      String?
  notes     String?
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())
  workerId  String
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  worker    Worker    @relation(fields: [workerId], references: [id])

  @@map("crew_assignments")
}

model PortfolioProject {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String?
  category    String
  coverImage  String?
  images      String[]
  location    String?
  completedAt DateTime?
  isPublished Boolean   @default(false)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("portfolio_projects")
}

model NewsArticle {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  content     String
  excerpt     String?
  coverImage  String?
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdById String
  createdBy   User          @relation(fields: [createdById], references: [id])

  @@map("news_articles")
}

model Page {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  content         Json
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("pages")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  createdAt DateTime @default(now())
  userId    String
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id            String   @id @default(cuid())
  type          String
  title         String
  body          String?
  isRead        Boolean  @default(false)
  relatedEntity String?
  relatedId     String?
  createdAt     DateTime @default(now())
  userId        String
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

model Setting {
  id        String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model FinancialTemplate {
  id                  String       @id @default(cuid())
  name                String
  description         String?
  taxationType        TaxationType
  globalMarginPercent Decimal      @db.Decimal(5, 2)
  logisticsCost       Decimal      @default(0) @db.Decimal(12, 2)
  categoryMargins     Json?
  createdById         String
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  createdBy           User         @relation("TemplateCreator", fields: [createdById], references: [id])

  @@index([createdById])
  @@map("financial_templates")
}

model TaxRecord {
  id                 String       @id @default(cuid())
  estimateId         String
  taxationType       TaxationType
  pdvAmount          Decimal      @db.Decimal(12, 2)
  esvAmount          Decimal      @db.Decimal(12, 2)
  militaryTaxAmount  Decimal      @db.Decimal(12, 2)
  profitTaxAmount    Decimal      @db.Decimal(12, 2)
  unifiedTaxAmount   Decimal      @db.Decimal(12, 2)
  pdfoAmount         Decimal      @db.Decimal(12, 2)
  totalTaxAmount     Decimal      @db.Decimal(12, 2)
  netProfit          Decimal      @db.Decimal(12, 2)
  effectiveTaxRate   Decimal      @db.Decimal(5, 2)
  calculationDetails Json?
  calculatedAt       DateTime     @default(now())

  @@index([estimateId])
  @@index([calculatedAt])
  @@map("tax_records")
}

enum Role {
  SUPER_ADMIN
  MANAGER
  CLIENT
  ENGINEER
  FINANCIER
  USER
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectStage {
  DESIGN
  FOUNDATION
  WALLS
  ROOF
  ENGINEERING
  FINISHING
  HANDOVER
}

enum StageStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
}

enum EstimateStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  REVISION
  ENGINEER_REVIEW
  FINANCE_REVIEW
}

enum TaxationType {
  CASH
  FOP
  VAT
}

enum EquipmentStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  DECOMMISSIONED
}

enum InventoryTransactionType {
  PURCHASE
  USAGE
  RETURN
  ADJUSTMENT
  TRANSFER
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum FileType {
  PHOTO_REPORT
  DOCUMENT
  PLAN
  COMPLETION_ACT
  ESTIMATE
}
