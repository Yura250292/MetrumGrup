  id        String           @id @default(cuid())
  name      String
  type      CounterpartyType @default(LEGAL)
  taxId     String?
  phone     String?
  email     String?
  address   String?
  notes     String?
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([isActive])
  @@index([type])
  @@index([name])
  @@map("counterparties")
}

// Receipt scan workflow: manager scans an invoice for a project, an approver
// (SUPER_ADMIN/MANAGER/FINANCIER) confirms, after which materials are posted to
// the project's warehouse and prices are stored as MaterialPriceSnapshot.
model ReceiptScan {
  id               String            @id @default(cuid())
  projectId        String
  warehouseId      String?
  status           ReceiptScanStatus @default(PENDING)
  source           ReceiptScanSource @default(WEB)
  supplier         String?
  documentDate     DateTime?
  totalAmount      Decimal?          @db.Decimal(12, 2)
  currency         String            @default("UAH")
  ocrText          String?           @db.Text
  ocrJson          Json?
  fileR2Key        String?
  fileMimeType     String?
  fileOriginalName String?
  notes            String?
  rejectionReason  String?
  createdById      String
  approvedById     String?
  approvedAt       DateTime?
  financeEntryId   String?           @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  project        Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  warehouse      Warehouse?              @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  createdBy      User                    @relation("ReceiptScanCreator", fields: [createdById], references: [id])
  approvedBy     User?                   @relation("ReceiptScanApprover", fields: [approvedById], references: [id])
  financeEntry   FinanceEntry?           @relation("FinanceEntryReceiptScan", fields: [financeEntryId], references: [id], onDelete: SetNull)
  lineItems      ReceiptLineItem[]
  priceSnapshots MaterialPriceSnapshot[]

  @@index([projectId, status])
  @@index([status, createdAt])
  @@map("receipt_scans")
}

model ReceiptLineItem {
  id                String                @id @default(cuid())
  scanId            String
  rawName           String
  rawUnit           String?
  quantity          Decimal               @db.Decimal(10, 3)
  unitPrice         Decimal               @db.Decimal(10, 2)
  totalPrice        Decimal?              @db.Decimal(12, 2)
  status            ReceiptLineItemStatus @default(UNMATCHED)
  matchedMaterialId String?
  matchConfidence   Float?
  proposedSku       String?
  proposedCategory  String?
  notes             String?
  sortOrder         Int                   @default(0)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  scan            ReceiptScan            @relation(fields: [scanId], references: [id], onDelete: Cascade)
  matchedMaterial Material?              @relation("MaterialReceiptLines", fields: [matchedMaterialId], references: [id], onDelete: SetNull)
  priceSnapshot   MaterialPriceSnapshot?

  @@index([scanId])
  @@index([matchedMaterialId])
  @@map("receipt_line_items")
}

// Per-purchase price record. Future estimates can pull last/avg/min price per
// material per supplier without losing the history when Material.basePrice changes.
model MaterialPriceSnapshot {
  id                String              @id @default(cuid())
  materialId        String
  price             Decimal             @db.Decimal(10, 2)
  unit              String
  quantity          Decimal?            @db.Decimal(10, 3)
  supplier          String?
  source            PriceSnapshotSource @default(RECEIPT_SCAN)
  occurredAt        DateTime
  projectId         String?
  warehouseId       String?
  receiptScanId     String?
  receiptLineItemId String?             @unique
  financeEntryId    String?
  createdById       String
  createdAt         DateTime            @default(now())

  material        Material         @relation(fields: [materialId], references: [id], onDelete: Cascade)
  project         Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  warehouse       Warehouse?       @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  receiptScan     ReceiptScan?     @relation(fields: [receiptScanId], references: [id], onDelete: SetNull)
  receiptLineItem ReceiptLineItem? @relation(fields: [receiptLineItemId], references: [id], onDelete: SetNull)
  financeEntry    FinanceEntry?    @relation(fields: [financeEntryId], references: [id], onDelete: SetNull)
  createdBy       User             @relation("PriceSnapshotCreator", fields: [createdById], references: [id])

  @@index([materialId, occurredAt])
  @@index([projectId, occurredAt])
  @@index([source])
  @@map("material_price_snapshots")
}

enum ReceiptScanStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ReceiptScanSource {
  WEB
  TELEGRAM
}

enum ReceiptLineItemStatus {
  MATCHED
  SUGGESTED
  UNMATCHED
  CONFIRMED
  CREATE_NEW
  SKIPPED
}

enum PriceSnapshotSource {
  RECEIPT_SCAN
  MANUAL
  ESTIMATE
  IMPORT
}
