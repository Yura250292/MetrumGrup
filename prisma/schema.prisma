// Task Layer (Worksection-style PM) — Phase 1: Task Core
// All models are additive — no existing tables modified.
// ============================================================

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskCustomFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  MULTI_SELECT
  URL
  USER
}

model Task {
  id                 String       @id @default(cuid())
  projectId          String
  stageId            String
  parentTaskId       String?
  statusId           String
  title              String
  description        String?      @db.Text
  priority           TaskPriority @default(NORMAL)
  startDate          DateTime?
  dueDate            DateTime?
  completedAt        DateTime?
  estimatedHours     Decimal?     @db.Decimal(8, 2)
  actualHours        Decimal      @default(0) @db.Decimal(10, 2)
  customFields       Json?
  position           Int          @default(0)
  isRecurring        Boolean      @default(false)
  recurrenceRule     String?
  recurrenceParentId String?
  isArchived         Boolean      @default(false)
  isPrivate          Boolean      @default(false)
  createdById        String
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  project            Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stage              ProjectStageRecord    @relation(fields: [stageId], references: [id], onDelete: Restrict)
  parentTask         Task?                 @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks           Task[]                @relation("TaskHierarchy")
  status             TaskStatus            @relation(fields: [statusId], references: [id], onDelete: Restrict)
  createdBy          User                  @relation("TaskCreator", fields: [createdById], references: [id])
  recurrenceParent   Task?                 @relation("TaskRecurrence", fields: [recurrenceParentId], references: [id])
  recurrenceChildren Task[]                @relation("TaskRecurrence")
  assignees          TaskAssignee[]
  watchers           TaskWatcher[]
  labels             TaskLabelAssignment[]
  checklist          ChecklistItem[]
  outgoingDeps       TaskDependency[]      @relation("TaskDepPredecessor")
  incomingDeps       TaskDependency[]      @relation("TaskDepSuccessor")
  timeLogs           TimeLog[]

  @@index([projectId, stageId, isArchived])
