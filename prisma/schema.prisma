// Окрема юридична особа / бізнес-одиниця в системі.
// Stable string ids: "metrum-group" (default), "metrum-studio".
// Фінанси, проекти, користувачі однієї фірми ізольовані від іншої:
// агрегації основного дашборду за замовчуванням обмежені firmId="metrum-group".
model Firm {
  id           String   @id
  slug         String   @unique
  name         String
  legalName    String?
  displayColor String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users             User[]
  projects          Project[]
  financeEntries    FinanceEntry[]
  folders           Folder[]
  userAccess        UserFirmAccess[]
  counterparties    Counterparty[]
  foremanReports    ForemanReport[]
  supplierPayments  SupplierPayment[]
  supplierMaterials SupplierMaterial[]
  meetings          Meeting[]

  @@map("firms")
}

// Per-firm role overrides. У User є базова `role` для його home firm (User.firmId).
// Додаткові фірми, до яких користувач має доступ, описуються у цій таблиці.
// Приклад: shymilo93 — base role=HR, firmId=metrum-group; UserFirmAccess рядок
// {firmId=metrum-studio, role=SUPER_ADMIN} робить його адміном на Studio.
//
// SUPER_ADMIN при базовому role: ця таблиця ігнорується, такий користувач
// SUPER_ADMIN на всіх фірмах автоматично (узгоджено з користувачем).
model UserFirmAccess {
  id        String   @id @default(cuid())
  userId    String
  firmId    String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@unique([userId, firmId])
  @@index([userId])
  @@index([firmId])
  @@map("user_firm_access")
}

model Folder {
  id                    String       @id @default(cuid())
  domain                FolderDomain
  name                  String
  color                 String?
  parentId              String?
  sortOrder             Int          @default(0)
  isSystem              Boolean      @default(false)
  slug                  String?
  mirroredFromId        String?      @unique
  mirroredFromProjectId String?      @unique
  /// Фірма-власник папки (Metrum Group / Studio). Використовується щоб
  /// дерева папок не leak-али між фірмами.
  firmId                String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  parent              Folder?                  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children            Folder[]                 @relation("FolderTree")
  mirroredFrom        Folder?                  @relation("FolderMirror", fields: [mirroredFromId], references: [id], onDelete: Cascade)
  mirrors             Folder[]                 @relation("FolderMirror")
  mirroredFromProject Project?                 @relation("FolderFromProject", fields: [mirroredFromProjectId], references: [id], onDelete: Cascade)
  firm                Firm?                    @relation(fields: [firmId], references: [id])
  projects            Project[]
  estimates           Estimate[]
  financeEntries      FinanceEntry[]
  financeTemplates    FinanceExpenseTemplate[]
  meetings            Meeting[]

  @@unique([domain, parentId, name])
  @@unique([domain, slug])
  @@index([domain, parentId, sortOrder])
  @@index([isSystem])
  @@index([firmId])
  @@map("folders")
}

