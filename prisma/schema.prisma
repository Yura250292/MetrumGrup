  rowNumber   Int? // Номер рядка в оригінальному документі
  category    String? // Розділ/секція (наприклад: "Земляні роботи", "Фундамент")
  code        String? // Код позиції (якщо є в кошторисі)
  description String  @db.Text // Опис позиції
  unit        String // Одиниця виміру (м², шт, м³, кг)
  quantity    Decimal @db.Decimal(12, 4)
  unitPrice   Decimal @db.Decimal(12, 2)
  totalPrice  Decimal @db.Decimal(12, 2)

  notes String? @db.Text // Додаткові примітки

  estimate ProzorroEstimateData @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
  @@index([category])
  @@index([description]) // Для пошуку схожих позицій
